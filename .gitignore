/target
**/*.rs.bk
Cargo.lock.bak
.mnemosyne/
.claude/
# Claude working scratch (RFC drafts, maintainer replies) — local only
/claudedocs/*
# Exception: experiment evidence is permanent audit record (not transient
# scratch) — preserved as git SSOT so conclusions stay re-checkable. The
# scratch .atomic.json stores stay out (R404 seeded-fixture rule); the
# manifests reproduce them via import-sections/import-facts.
!/claudedocs/phase1-scale-floor-experiment/
!/claudedocs/phase1-drift-acceptance/
!/claudedocs/phase1-causes-poc/
/claudedocs/phase1-causes-poc/*.atomic.json
!/claudedocs/phase1-rung3-poc/
/claudedocs/phase1-rung3-poc/*.atomic.json
!/claudedocs/phase1-selfextract-poc/
/claudedocs/phase1-selfextract-poc/*.atomic.json
!/claudedocs/phase1-factsfirst-poc/
/claudedocs/phase1-factsfirst-poc/*.atomic.json
!/claudedocs/phase1-factsfirst-craft-experiment/
/claudedocs/phase1-factsfirst-craft-experiment/*.atomic.json
!/claudedocs/phase1-disclosure-craft-experiment/
/claudedocs/phase1-disclosure-craft-experiment/*.atomic.json
!/claudedocs/phase1-ai-authoring-experiment/
/claudedocs/phase1-ai-authoring-experiment/*.atomic.json
!/claudedocs/phase1-convergence-probe/
/claudedocs/phase1-convergence-probe/**/*.atomic.json
!/claudedocs/phase1-ai-npc-breadth-experiment/
/claudedocs/phase1-ai-npc-breadth-experiment/**/*.atomic.json
/claudedocs/phase1-ai-npc-breadth-experiment/**/*.playthrough.json
