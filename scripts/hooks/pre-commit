#!/usr/bin/env bash
# mnemosyne pre-commit hook — DESIGN §66 *self-application* (- 79 OPTION C
# carry, - 146 generic via mnemosyne.toml, - 168 cascade auto-update).
#
# Three gates:
# 1. workspace doc gate — validate-workspace whenever a tracked doc
# (per `mnemosyne-cli list-docs`) is staged.
# 2. atomic sidecar gate — verify-generated whenever the atomic store
# sidecar `docs/.atomic/workspace.atomic.json` is staged. Rejects the
# commit if GENERATED.md is stale (- 168 cascade auto-update gate).
# 3. code citation gate (Round 257) — validate-code-refs always runs;
# the subcommand internally skips when `[code_refs]` is unconfigured
# in `mnemosyne.toml` (5-min setup carry), otherwise scans configured
# paths for citations whose target entry_id is missing from atomic.
#
# -: scripts/install-hooks.sh - -
# `cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x ...`.

set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACMR || true)
ATOMIC_SIDECAR="docs/.atomic/workspace.atomic.json"

# Gate 2 — atomic sidecar staged → GENERATED.md must be in sync.
if printf '%s\n' "$staged" | grep -qx -- "$ATOMIC_SIDECAR"; then
 echo "[mnemosyne pre-commit] atomic sidecar staged — verify-generated"
 if ! cargo run -q -p mnemosyne-cli -- verify-generated; then
 echo "[mnemosyne pre-commit] commit rejected — GENERATED.md stale" >&2
 echo " fix: cargo run -q -p mnemosyne-cli -- generate-docs && git add docs/GENERATED.md" >&2
 exit 1
 fi
fi

# Gate 3 (Round 257) — code citation defense. Subcommand internally
# skips when [code_refs] is unconfigured. When configured with
# severity_missing = "reject", missing citations block the commit.
echo "[mnemosyne pre-commit] code citation defense — validate-code-refs"
if ! cargo run -q -p mnemosyne-cli -- validate-code-refs; then
 echo "[mnemosyne pre-commit] commit rejected — code citation violations" >&2
 echo " fix: verify each cited entry_id exists in atomic store, or" >&2
 echo " register stale citations in mnemosyne.toml [[orphan_ledger]]" >&2
 exit 1
fi

# Gate 1 — resolve the configured doc list via the CLI itself (single
# source of truth: mnemosyne.toml). Failure here means the config is
# missing or the binary cannot build — fall through to the unconditional
# validate so the user sees the underlying error from `cargo run`.
if doc_list=$(cargo run -q -p mnemosyne-cli -- list-docs 2>/dev/null); then
 needs_validate=0
 while IFS= read -r p; do
 [[ -z "$p" ]] && continue
 if printf '%s\n' "$staged" | grep -qx -- "$p"; then
 needs_validate=1
 break
 fi
 done <<< "$doc_list"

 if [[ "$needs_validate" == "0" ]]; then
 exit 0
 fi
fi

echo "[mnemosyne pre-commit] design_doc - - — validate-workspace"
cargo run -q -p mnemosyne-cli -- validate-workspace

# - 131 — style violation delta surface (warn-only carry, - 138 reject -).
# validate-workspace - - T3 warn / T4 info count -; - hook - - hint -.
echo "[mnemosyne pre-commit] style violation count - - 138 closure round - strict reject - carry."
