#!/usr/bin/env bash
# Mnemosyne self-application pre-commit gate — runs on every `git commit`.
#
# Mnemosyne dogfoods its own validator against the repo's atomic store +
# GENERATED.md round-trip + code citation defense before every commit.
# Plus a clippy gate when `.rs` files are staged (workspace lint baseline).
#
# Gates:
#
#   2. Code citation defense — `mnemosyne-cli validate-code-refs`
#      always runs; subcommand silently skips when
#      `[plugins.set_equality_validator]` is unconfigured (5-min setup
#      promise). Otherwise scans `paths` for `<entry_id_prefix><digits>`
#      and `§<id>` citations and rejects on hallucination / unbound /
#      decay / inventory / symbol-mismatch violations (severity per config).
#
#   3. Workspace gate — `mnemosyne-cli validate-workspace` when any
#      tracked doc (per `mnemosyne-cli list-docs`) is staged. Store-direct:
#      T1 orphan delta, T2 frozen-ledger, T3/T4 style, divergence /
#      ledger match, commit↔ledger drift.
#
#   4. Format gate — `cargo fmt --all --check` when any `.rs` file is
#      staged. rustfmt 4-space repo-wide (rustfmt.toml, edition 2021);
#      rejects unformatted code so layout stays uniform.
#
#   5. Clippy gate — `cargo clippy --workspace --all-targets -- -D warnings`
#      when any `.rs` file is staged. R308 D9 closure (warnings → deny
#      baseline): any new clippy warning trips the gate. Workspace-level
#      allow list in root Cargo.toml covers `doc_lazy_continuation` (rustdoc
#      renders both forms) and `inconsistent_digit_grouping` (YYYY_MM_DD
#      date u64 literals). Per-site `#[allow]` for API-shape exemptions
#      (`result_large_err` on tonic interceptors; `too_many_arguments` on
#      the `scan_paths_no_resolvers` test helper).
#
# Install (one-time per clone):
#   git config core.hooksPath .githooks
#
# Bypass: `--no-verify` (discouraged; the project policy treats audit
# gates as load-bearing, not nudges).

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

ATOMIC_SIDECAR="docs/.atomic/workspace.atomic.json"

# Prefer the release binary if it exists (much faster than `cargo run`).
# Falls back to `cargo run -q -p mnemosyne-cli --` so the hook still works
# pre-first-build (e.g., a fresh clone running its first commit).
if [[ -x "target/release/mnemosyne-cli" ]]; then
    cli=(target/release/mnemosyne-cli)
elif command -v mnemosyne-cli >/dev/null 2>&1; then
    cli=(mnemosyne-cli)
else
    cli=(cargo run -q -p mnemosyne-cli --)
fi

staged=$(git diff --cached --name-only --diff-filter=ACMR || true)

# Gate 2 — code citation defense (R257+). Internally skips when
# [plugins.set_equality_validator] is unconfigured.
echo "[mnemosyne pre-commit] code citation defense — validate-code-refs" >&2
if ! "${cli[@]}" validate-code-refs; then
    {
        echo "[mnemosyne pre-commit] commit rejected — code citation violations"
        echo "  fix: verify each cited entry_id / §<id> / inventory id exists,"
        echo "       or register stale citations in mnemosyne.toml [[orphan_ledger]]"
    } >&2
    exit 1
fi

# Gate 3 — workspace validate when any configured doc is staged.
needs_validate=0
if doc_list=$("${cli[@]}" list-docs 2>/dev/null); then
    while IFS= read -r p; do
        [[ -z "$p" ]] && continue
        if printf '%s\n' "$staged" | grep -qx -- "$p"; then
            needs_validate=1
            break
        fi
    done <<< "$doc_list"
fi

if [[ "$needs_validate" == "1" ]]; then
    echo "[mnemosyne pre-commit] doc staged — validate-workspace" >&2
    "${cli[@]}" validate-workspace
fi

# Gate 4 — rustfmt on .rs changes. Enforces the 4-space repo-wide baseline
# (rustfmt.toml); rejects unformatted code so the layout stays uniform.
if printf '%s\n' "$staged" | grep -qE '\.rs$'; then
    echo "[mnemosyne pre-commit] .rs staged — cargo fmt --all --check" >&2
    if ! cargo fmt --all --check; then
        {
            echo "[mnemosyne pre-commit] commit rejected — unformatted code"
            echo "  fix: cargo fmt --all && git add -u"
        } >&2
        exit 1
    fi
fi

# Gate 5 — clippy on .rs changes. R308 D9 closure: `-D warnings` lifts
# every warning to deny. Workspace allow list (root Cargo.toml) carries
# stylistic exemptions; per-site `#[allow]` for API-shape exemptions.
if printf '%s\n' "$staged" | grep -qE '\.rs$'; then
    echo "[mnemosyne pre-commit] .rs staged — cargo clippy --workspace --all-targets -- -D warnings" >&2
    cargo clippy --workspace --all-targets -- -D warnings
fi

# Gate 6 — vN version-postfix identifier ban (CLAUDE.md anti-pattern).
# Extending a definition must modify it in place; no `foo_v2` / `BarV3`
# version postfixes anywhere — production OR test fixtures/names/data.
# Scans ADDED lines in staged `.rs` files. `_v[0-9]` intentionally does
# not match `_version` (schema_version etc. are real version numbers).
if printf '%s\n' "$staged" | grep -qE '\.rs$'; then
    echo "[mnemosyne pre-commit] .rs staged — vN version-postfix ban" >&2
    vn_hits=$(git diff --cached --unified=0 --diff-filter=ACM -- '*.rs' \
        | grep -E '^\+' | grep -vE '^\+\+\+' \
        | grep -E '[A-Za-z0-9]_v[0-9]|[a-z0-9]V[0-9]' || true)
    if [[ -n "$vn_hits" ]]; then
        {
            echo "[mnemosyne pre-commit] commit rejected — vN version-postfix identifier"
            echo "  banned: foo_v2 / BarV3 version postfixes — extend the definition in place."
            echo "  offending added lines:"
            printf '%s\n' "$vn_hits" | sed 's/^/    /'
        } >&2
        exit 1
    fi
fi
