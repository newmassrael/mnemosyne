#!/usr/bin/env bash
# pre-push hook — re-run integrity + lint gates before publishing
# commits to a remote.
#
# Push is the natural integrity-gate point: this is where the project's
# audit-traced state becomes shared. Catches state changes since last
# commit (manual atomic.json edits, amends, rebases, `--no-verify`
# bypasses) that pre-commit may have missed.
#
# Exception: delete-only pushes (branch/tag deletions) publish no commits,
# so there is nothing to validate — they skip all gates (see delete_only
# below). Drift on the working state is caught on the next commit push.
#
# Checks:
#
#   1. `mnemosyne-cli validate-workspace` (store-direct, the SSOT)
#      - T1 prose cross-ref orphan delta
#      - T2 frozen-ledger violations
#      - T3/T4 style violations
#      - Atomic ledger consistency (entries / sections / orphan refs)
#      - Publishable / audit divergence ↔ override ledger match (R296)
#      - Commit ↔ ledger drift (cited vs entries scan)
#
#   2. `cargo fmt --all --check`
#      - rustfmt 4-space repo-wide baseline (rustfmt.toml, edition 2021).
#
#   3. `cargo clippy --workspace --all-targets -- -D warnings`
#      - R308 D9 closure: every warning lifts to deny. Workspace allow
#        list (root Cargo.toml) carries stylistic exemptions
#        (`doc_lazy_continuation`, `inconsistent_digit_grouping`);
#        per-site `#[allow]` for API-shape exemptions.
#      - Unconditional (push validates publishable state, so the clippy
#        budget is paid once per push regardless of which files changed).
#
# Install (one-time per clone):
#   git config core.hooksPath .githooks

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Skip the gates for delete-only pushes. Git feeds one line per ref update on
# stdin ("<local_ref> <local_sha> <remote_ref> <remote_sha>"); a deletion has
# an all-zero <local_sha> and publishes no commits, so there is nothing to
# validate. If every ref update is a deletion, exit clean. (An empty stdin —
# no ref updates — is likewise nothing to publish.)
delete_only=1
while read -r _local_ref local_sha _remote_ref _remote_sha; do
    [[ -z "${local_sha:-}" ]] && continue
    if [[ ! "$local_sha" =~ ^0+$ ]]; then
        delete_only=0
    fi
done
if [[ "$delete_only" -eq 1 ]]; then
    echo "pre-push: delete-only push (no commits to validate) — skipping gates" >&2
    exit 0
fi

# Prefer the release binary if it exists (much faster than `cargo run`).
if [[ -x "target/release/mnemosyne-cli" ]]; then
    cli=(target/release/mnemosyne-cli)
elif command -v mnemosyne-cli >/dev/null 2>&1; then
    cli=(mnemosyne-cli)
else
    cli=(cargo run -q -p mnemosyne-cli --)
fi

echo "pre-push: ${cli[*]} validate-workspace ..." >&2
if ! "${cli[@]}" validate-workspace; then
    echo "pre-push: validate-workspace failed — fix violations before push" >&2
    exit 1
fi

echo "pre-push: cargo fmt --all --check ..." >&2
if ! cargo fmt --all --check; then
    echo "pre-push: unformatted code — run cargo fmt --all before push" >&2
    exit 1
fi

echo "pre-push: cargo clippy --workspace --all-targets -- -D warnings ..." >&2
if ! cargo clippy --workspace --all-targets -- -D warnings; then
    echo "pre-push: clippy failed — fix violations before push" >&2
    exit 1
fi

exit 0
